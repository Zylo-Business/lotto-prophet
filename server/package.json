{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch . --ext ts --ignore dist/ --exec \"tsx index.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx utils/seed-csv.ts",
    "seed:alpha": "tsx utils/seed-csv.ts \"db/alpha m.csv\"",
    "seed:lucky": "tsx utils/seed-csv.ts \"db/lucky.csv\"",
    "seed:all": "tsx utils/seed-csv.ts \"db/alpha m.csv\" --clear && tsx utils/seed-csv.ts \"db/lucky.csv\"",
    "seed:clear": "tsx utils/seed-csv.ts --clear",
    "sync:drive": "tsx utils/sync-google-drive.ts",
    "schedule:sync": "tsx utils/schedule-sync.ts",
    "migrate": "tsx utils/migrate-mysql-to-postgres.ts",
    "admin:create": "tsx utils/create-admin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "googleapis": "118.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "xlsx": "^0.18.5"
    
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.33",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "mysql2": "^3.22.3",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }

}

